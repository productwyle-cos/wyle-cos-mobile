# API
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT=10000

# App
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0

# Anthropic (Claude AI — used by Buddy chat + Life Signal Engine)
# Get from: https://console.anthropic.com/settings/api-keys
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper — voice-to-text on mobile iOS/Android)
# Get from: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Google OAuth (Gmail + Calendar — Life Signal Engine)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
#
# Web application client (for browser / Codespaces preview)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Web application client SECRET — required for token exchange on web.
# Click your Web client in Google Cloud Console → copy "Client secret"
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your-web-client-secret
#
# Android OAuth client — Application type: Android, Package: com.wyle.cos
# Get SHA-1 via: npx eas credentials --platform android
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
# iOS OAuth client — Application type: iOS, Bundle ID: com.wyle.cos
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com

# WhatsApp Backend (Wyle COS Backend — Render.com)
# The backend URL and API secret for the WhatsApp session manager
EXPO_PUBLIC_WHATSAPP_BACKEND_URL=https://wyle-cos-backend.onrender.com
EXPO_PUBLIC_WHATSAPP_API_SECRET=your-api-secret-here
